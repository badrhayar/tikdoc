# Root-level ignores

# Dependencies
node_modules/

# Environment variables — never commit real secrets
.env
.env.*
!.env.example

# Build output
dist/

# Packaged project archives (delivered to the user, never committed — a full
# source archive alongside the deploy is a needless exposure surface)
*.zip

# Manual backups (scripts/backup.sh output) — data, never commit
backups/

# TWA / Play Store build artifacts — keystore is PERMANENT, keep it out of git
twa/*.keystore
twa/*.jks
twa/*.aab
twa/*.apk
twa/.gradle/
twa/app/
twa/android.keystore
twa/*.keystore.txt

# Supabase CLI local files
.supabase/
supabase/.temp/

# OS / editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea
*.log
