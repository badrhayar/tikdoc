# Tabibo · backup.sh configuration
# Copy this file to  scripts/.env  and fill in the real values.
# scripts/.env is git-ignored — never commit real secrets.

# Full Postgres connection string.
#   Dashboard → Settings → Database → Connection string → URI
#   Replace [YOUR-PASSWORD] with your database password.
SUPABASE_DB_URL="postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# Your project URL.  Dashboard → Settings → API → Project URL
SUPABASE_URL="https://xxxxxxxx.supabase.co"

# service_role key (the SECRET one).  Dashboard → Settings → API → service_role
# Full read access to Storage — keep it private, exactly like the Vault key.
SUPABASE_SERVICE_KEY="eyJhbGciOi...paste-service_role-key..."

# ── Optional overrides ───────────────────────────────────────────────────────
# BACKUP_DIR="/absolute/path/to/backups"   # default: <repo>/backups
# RETENTION="7"                            # how many backups to keep
# BUCKETS="documents avatars credentials chat-media"
