# ─────────────────────────────────────────────────────────────
# TikDoc · frontend environment variables
# Copy this file to `.env` (same folder) and fill in real values.
# Get them in Supabase: Project Settings → API.
#
# NOTE: Vite only exposes variables prefixed with VITE_ to the browser.
# These two correspond to your project's SUPABASE_URL and SUPABASE_ANON_KEY.
# The anon key is safe to ship to the client — Row Level Security protects data.
# Never put the service_role key here.
# ─────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Map (MapLibre + MapTiler). Get a free key at https://maptiler.com (no credit card).
# Without it the map still works using MapLibre's free demo style.
VITE_MAPTILER_KEY=YOUR-MAPTILER-KEY
